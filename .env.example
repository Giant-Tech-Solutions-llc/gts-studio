# ─────────────────────────────────────────────────────────────
# Anthropic — REQUIRED. Server-side only; never exposed to client.
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Auth — single access-code gate (default).
#   ACCESS_CODE: the shared code users type on /login.
#   AUTH_SECRET: random 32+ char string used to sign the session cookie.
#                Generate with:  openssl rand -base64 32
# If you prefer multi-user auth, swap the middleware for NextAuth and set
# the NextAuth vars instead (NEXTAUTH_URL / NEXTAUTH_SECRET / provider keys).
# ─────────────────────────────────────────────────────────────
ACCESS_CODE=change-me-to-a-strong-shared-code
AUTH_SECRET=change-me-generate-a-32-char-random-string

# ─────────────────────────────────────────────────────────────
# KV store (Upstash Redis / Vercel KV) — for rate limiting,
# usage logging, and run history. Optional in local dev: if unset,
# the app runs with rate limiting + history disabled (logs a warning).
# Provision via Vercel → Storage → Upstash Redis, then pull with
#   vercel env pull .env.local
# ─────────────────────────────────────────────────────────────
# The app also accepts the Upstash Marketplace names interchangeably:
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Optional tuning
# ─────────────────────────────────────────────────────────────
# Requests allowed per user per sliding 60s window (default 30).
RATE_LIMIT_PER_MINUTE=30
